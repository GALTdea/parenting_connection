<div class="dropdown dropdown-end">
  <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar placeholder">
    <div class="bg-primary text-primary-content rounded-full w-9">
      <span class="text-sm font-medium">
        <%= current_user.name.to_s.strip.presence&.first&.upcase || "U" %>
      </span>
    </div>
  </div>
  <ul tabindex="0"
      class="dropdown-content menu bg-base-100 rounded-box z-50 w-52 p-2 shadow-lg border border-base-300 mt-2">
    <li class="menu-title">
      <span><%= current_user.name.to_s.strip.presence || current_user.email %></span>
    </li>
    <div class="divider my-1"></div>
    <li>
      <%= link_to "Change password", edit_user_registration_path %>
    </li>
    <% if current_user.admin? %>
      <div class="divider my-1"></div>
      <li>
        <%= link_to "Setup", edit_setup_path, target: "_blank" %>
      </li>
    <% end %>
    <div class="divider my-1"></div>
    <li>
      <%= button_to "Logout", destroy_user_session_path,
        method: :delete,
        data: { turbo: false },
        class: "btn btn-ghost btn-sm justify-start font-normal w-full" %>
    </li>
  </ul>
</div>
