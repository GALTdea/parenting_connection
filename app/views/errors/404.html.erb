<!DOCTYPE html>
<html lang="en" data-theme="starter_light">
  <head>
    <title>Page Not Found — My Rails Starter</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= stylesheet_link_tag "tailwind",
      "data-turbo-track": "reload" %>
  </head>
  <body class="min-h-screen bg-base-200 flex items-center
               justify-center p-4">
    <div class="text-center max-w-md">
      <p class="text-8xl font-black text-base-300 mb-4">
        404
      </p>
      <h1 class="text-2xl font-bold text-base-content mb-2">
        Page not found
      </h1>
      <p class="text-base-content/60 mb-8">
        The page you're looking for doesn't exist
        or has been moved.
      </p>
      <%= link_to "Go home", root_path,
        class: "btn btn-primary" %>
    </div>
  </body>
</html>
