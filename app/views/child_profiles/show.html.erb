<% content_for :breadcrumb do %>
  <%= link_to "Children", child_profiles_path, class: "link link-hover" %>
  <span class="mx-2">/</span>
  <%= @child_profile.name %>
<% end %>

<div class="mx-auto flex w-full max-w-3xl flex-col gap-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-medium text-primary">Child profile</p>
      <h1 class="text-3xl font-bold tracking-normal text-base-content"><%= @child_profile.name %></h1>
    </div>

    <div class="flex flex-col gap-2 sm:flex-row">
      <%= link_to "Edit", edit_child_profile_path(@child_profile), class: "btn btn-primary w-full sm:w-auto" %>
      <%= button_to "Remove",
            @child_profile,
            method: :delete,
            form: { data: { turbo_confirm: "Remove this child profile?" } },
            class: "btn btn-ghost w-full sm:w-auto" %>
    </div>
  </div>

  <section class="rounded-lg bg-base-100 p-6 shadow-sm">
    <dl class="grid gap-4 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-base-content/60">First name or nickname</dt>
        <dd class="mt-1 text-lg font-semibold text-base-content"><%= @child_profile.name %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-base-content/60">Birthday</dt>
        <dd class="mt-1 text-lg font-semibold text-base-content"><%= @child_profile.birthday.to_fs(:long) %></dd>
      </div>
    </dl>
  </section>

  <section class="rounded-lg bg-base-100 p-6 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-medium text-primary">Daily ritual</p>
        <h2 class="text-2xl font-semibold text-base-content">Responses</h2>
      </div>

      <%= link_to "Answer a question",
            new_child_profile_memory_response_path(@child_profile),
            class: "btn btn-primary w-full sm:w-auto" %>
    </div>

    <% if @memory_responses.any? %>
      <div class="mt-5 space-y-4">
        <% @memory_responses.each do |memory_response| %>
          <article id="<%= dom_id(memory_response) %>" class="rounded-lg border border-base-300 p-4">
            <div class="space-y-2">
              <p class="text-sm font-medium text-base-content/60">
                <%= memory_response.answered_on.to_fs(:long) %>
              </p>
              <h3 class="text-lg font-semibold text-base-content">
                <%= memory_response.daily_question.prompt %>
              </h3>
              <p class="whitespace-pre-line text-base-content/80"><%= memory_response.response_text %></p>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="mt-5 rounded-lg border border-dashed border-base-300 p-5">
        <p class="text-base-content/70">
          No responses yet. Start with one question and save the words you want to remember.
        </p>
      </div>
    <% end %>
  </section>
</div>
