<!DOCTYPE html>
<html lang="en" data-theme="starter_light">
  <head>
    <%= display_meta_tags(
  site: "My Rails Starter",
  title: "Dashboard",
  separator: "·"
) %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= javascript_importmap_tags %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>
  <body class="min-h-screen bg-base-200">
    <div class="drawer lg:drawer-open">
      <input id="drawer-toggle" type="checkbox" class="drawer-toggle" />

      <!-- Main content -->
      <div class="drawer-content flex flex-col">
        <!-- Top navbar -->
        <nav class="navbar bg-base-100 border-b border-base-300 px-4 lg:px-6">
          <!-- Mobile drawer toggle -->
          <div class="flex-none lg:hidden">
            <label for="drawer-toggle" class="btn btn-square btn-ghost">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                   class="inline-block w-5 h-5 stroke-current">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </label>
          </div>

          <!-- App name / breadcrumb area -->
          <div class="flex-1 px-2">
            <span class="text-sm font-medium text-base-content/60">
              <%= content_for(:breadcrumb) || "" %>
            </span>
          </div>

          <!-- Right side: user menu -->
          <div class="flex-none">
            <%= render "shared/user_menu" %>
          </div>
        </nav>

        <!-- Page content -->
        <main class="flex-1 p-4 lg:p-6">
          <%= render "shared/flash" %>
          <%= yield %>
        </main>
      </div>

      <!-- Sidebar -->
      <div class="drawer-side z-40">
        <label for="drawer-toggle" class="drawer-overlay"></label>
        <aside class="bg-base-100 border-r border-base-300 w-64 min-h-screen flex flex-col">
          <!-- Logo -->
          <div class="px-6 py-4 border-b border-base-300">
            <%= link_to root_path, class: "text-xl font-bold text-primary" do %>
              My Rails Starter
            <% end %>
          </div>

          <!-- Navigation -->
          <nav class="flex-1 px-3 py-4">
            <ul class="menu menu-sm w-full gap-1">
              <li>
                <%= link_to spaces_path,
                  class: "flex items-center gap-3 #{current_page?(spaces_path) ? 'active' : ''}" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none"
                       viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                  </svg>
                  Spaces
                <% end %>
              </li>

              <% if current_user&.admin? %>
                <li class="menu-title mt-4">
                  <span>Admin</span>
                </li>
                <li>
                  <%= link_to edit_setup_path,
                    class: "flex items-center gap-3 #{current_page?(edit_setup_path) ? 'active' : ''}" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Setup
                  <% end %>
                </li>
              <% end %>
            </ul>
          </nav>

          <!-- Sidebar footer -->
          <div class="px-3 py-4 border-t border-base-300">
            <%= render "shared/user_menu_compact" %>
          </div>
        </aside>
      </div>
    </div>
  </body>
</html>

