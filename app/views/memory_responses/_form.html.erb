<%= form_with(model: [ child_profile, memory_response ], class: "space-y-5") do |form| %>
  <% if memory_response.errors.any? %>
    <div class="alert alert-error">
      <div>
        <h2 class="font-semibold">Please check the response.</h2>
        <ul class="mt-2 list-disc pl-5 text-sm">
          <% memory_response.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <% if selected_daily_question.present? %>
    <% if selected_daily_question_selection.present? %>
      <%= hidden_field_tag :daily_question_selection_id, selected_daily_question_selection.id %>
    <% end %>

    <section class="rounded-lg border border-base-300 bg-base-100 p-5">
      <p class="text-sm font-medium text-primary">Today's question</p>
      <h2 class="mt-2 text-2xl font-semibold leading-snug text-base-content">
        <%= selected_presented_prompt.presence || selected_daily_question.prompt %>
      </h2>
      <p class="mt-3 text-base-content/70">
        Save what <%= child_profile.name %> said, or add a note you want to remember.
      </p>
    </section>
  <% end %>

  <div class="form-control w-full">
    <%= form.label :daily_question_id,
          selected_daily_question.present? ? "Use a different question" : "Question",
          class: "label font-medium" %>
    <%= form.collection_select :daily_question_id,
          daily_questions,
          :id,
          :prompt,
          { prompt: selected_daily_question.present? ? nil : "Choose a question" },
          class: "select select-bordered w-full" %>
  </div>

  <div class="form-control w-full">
    <%= form.label :response_text, "What did your child say?", class: "label font-medium" %>
    <%= form.text_area :response_text,
          rows: 8,
          class: "textarea textarea-bordered min-h-40 w-full",
          placeholder: "Notes you want to remember",
          autofocus: true %>
  </div>

  <section class="rounded-lg border border-base-300 p-4" data-controller="voice-recorder">
    <div class="space-y-4">
      <div>
        <h2 class="text-lg font-semibold text-base-content">Record a voice memory</h2>
        <p class="mt-1 text-sm text-base-content/70">
          Voice memories are for meaningful conversation moments, not continuous recording. You can save text, voice, or both.
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <button type="button"
                class="btn btn-outline w-full sm:w-auto"
                data-voice-recorder-target="startButton"
                data-action="voice-recorder#start">
          Start recording
        </button>
        <button type="button"
                class="btn btn-outline w-full sm:w-auto"
                data-voice-recorder-target="stopButton"
                data-action="voice-recorder#stop">
          Stop recording
        </button>
        <span class="text-sm font-medium text-base-content/70" data-voice-recorder-target="timer">0:00</span>
      </div>

      <p class="text-sm text-base-content/70" data-voice-recorder-target="status">
        Your browser will ask for microphone permission before recording.
      </p>

      <audio class="w-full" controls hidden data-voice-recorder-target="audio"></audio>

      <button type="button"
              class="btn btn-ghost btn-sm"
              hidden
              data-voice-recorder-target="removeButton"
              data-action="voice-recorder#remove">
        Remove recording
      </button>

      <div class="form-control w-full">
        <%= form.label :voice_recording, "Audio file", class: "label font-medium" %>
        <%= form.file_field :voice_recording,
              accept: MemoryResponse::ALLOWED_VOICE_RECORDING_CONTENT_TYPES.join(","),
              class: "file-input file-input-bordered w-full",
              data: {
                voice_recorder_target: "fileInput",
                action: "change->voice-recorder#fileSelected"
              } %>
        <p class="mt-2 text-xs text-base-content/60">
          Recordings can be up to 15 minutes and 100 MB.
        </p>
      </div>

      <%= form.hidden_field :voice_recording_duration_seconds,
            data: { voice_recorder_target: "durationInput" } %>
    </div>
  </section>

  <div class="form-control w-full">
    <%= form.label :answered_on, "Date", class: "label font-medium" %>
    <%= form.date_field :answered_on, class: "input input-bordered w-full" %>
  </div>

  <div class="flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:justify-end">
    <%= link_to "Cancel", child_profile_path(child_profile), class: "btn btn-ghost w-full sm:w-auto" %>
    <%= form.submit "Save memory", class: "btn btn-primary w-full sm:w-auto" %>
  </div>
<% end %>
