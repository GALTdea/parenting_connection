<% content_for :breadcrumb do %>
  <%= link_to "Children", child_profiles_path, class: "link link-hover" %>
  <span class="mx-2">/</span>
  <%= @child_profile.name %>
<% end %>

<div class="mx-auto flex w-full max-w-3xl flex-col gap-6">
  <section class="rounded-lg bg-base-100 p-6 shadow-sm">
    <div class="space-y-6">
      <div class="space-y-2">
        <p class="text-sm font-medium text-primary">Today's conversation</p>
        <h1 class="text-3xl font-bold tracking-normal text-base-content"><%= @child_profile.name %></h1>
        <p class="text-base-content/70">
          One small question can become a memory you both get to keep.
        </p>
      </div>

      <% if @todays_question.present? %>
        <div class="rounded-lg border border-base-300 bg-base-100 p-5">
          <p class="text-sm font-medium text-base-content/60">Today's question</p>
          <h2 class="mt-2 text-2xl font-semibold leading-snug text-base-content">
            <%= @todays_question_selection.presented_prompt.presence || @todays_question.prompt %>
          </h2>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row">
          <%= link_to "Answer today's question",
                new_child_profile_memory_response_path(@child_profile, daily_question_selection_id: @todays_question_selection.id),
                class: "btn btn-primary w-full sm:w-auto" %>
          <%= link_to "Memory archive",
                child_profile_memory_responses_path(@child_profile),
                class: "btn btn-outline w-full sm:w-auto" %>
        </div>
      <% else %>
        <div class="rounded-lg border border-dashed border-base-300 p-5">
          <h2 class="text-xl font-semibold text-base-content">No questions are ready yet</h2>
          <p class="mt-2 text-base-content/70">
            Add active daily questions before capturing a new memory.
          </p>
        </div>
      <% end %>
    </div>
  </section>

  <section class="rounded-lg bg-base-100 p-6 shadow-sm">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-medium text-primary">Memory archive</p>
        <h2 class="text-2xl font-semibold text-base-content">Recent memories</h2>
      </div>

      <%= link_to "Open archive",
            child_profile_memory_responses_path(@child_profile),
            class: "btn btn-ghost w-full sm:w-auto" %>
    </div>

    <% if @memory_responses.any? %>
      <div class="mt-5 space-y-4">
        <% @memory_responses.each do |memory_response| %>
          <article id="<%= dom_id(memory_response) %>" class="rounded-lg border border-base-300 p-4">
            <div class="space-y-2">
              <p class="text-sm font-medium text-base-content/60">
                <%= memory_response.answered_on.to_fs(:long) %>
              </p>
              <h3 class="text-lg font-semibold text-base-content">
                <%= link_to memory_response.prompt_text,
                      child_profile_memory_response_path(@child_profile, memory_response),
                      class: "link-hover" %>
              </h3>
              <% if memory_response.voice_recording.attached? %>
                <p class="text-sm font-medium text-primary">Includes voice</p>
              <% end %>
              <% if memory_response.response_text.present? %>
                <p class="whitespace-pre-line text-base-content/80"><%= memory_response.response_text %></p>
              <% else %>
                <p class="text-base-content/70">Voice memory saved for this question.</p>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="mt-5 rounded-lg border border-dashed border-base-300 p-5">
        <div class="max-w-xl space-y-3">
          <h3 class="text-lg font-semibold text-base-content">This archive will grow one conversation at a time</h3>
          <p class="text-base-content/70">
            Start with one small moment. Answer today's question and save the words you want to remember.
          </p>
        </div>
      </div>
    <% end %>
  </section>

  <section class="rounded-lg bg-base-100 p-6 shadow-sm">
    <div class="space-y-5">
      <div>
        <p class="text-sm font-medium text-primary">Profile details</p>
        <h2 class="text-xl font-semibold text-base-content">About <%= @child_profile.name %></h2>
      </div>

      <dl class="grid gap-4 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-base-content/60">First name or nickname</dt>
          <dd class="mt-1 text-lg font-semibold text-base-content"><%= @child_profile.name %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-base-content/60">Birthday</dt>
          <dd class="mt-1 text-lg font-semibold text-base-content"><%= @child_profile.birthday.to_fs(:long) %></dd>
        </div>
      </dl>

      <div class="flex flex-col gap-2 border-t border-base-200 pt-4 sm:flex-row">
        <%= link_to "Edit profile", edit_child_profile_path(@child_profile), class: "btn btn-outline w-full sm:w-auto" %>
        <%= button_to "Remove profile",
              @child_profile,
              method: :delete,
              form: { data: { turbo_confirm: "Remove this child profile?" } },
              class: "btn btn-ghost w-full sm:w-auto" %>
      </div>
    </div>
  </section>
</div>
