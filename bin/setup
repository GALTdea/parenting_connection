#!/usr/bin/env bash
set -e

echo "== Setting up $(basename $PWD) =="

echo "\n-- Installing Ruby gems --"
bundle install

echo "\n-- Installing npm packages --"
npm install

echo "\n-- Preparing database --"
bin/rails db:prepare

echo "\n-- Loading seed data --"
bin/rails db:seed

echo "\n-- Done! =="
echo "Run bin/dev to start the server."
echo "Run bundle exec rspec to run the test suite."
