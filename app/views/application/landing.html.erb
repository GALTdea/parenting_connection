<% set_meta_tags(
  title: "A private daily conversation ritual",
  description: "Parenting Connection helps parents preserve meaningful conversations with their children in a calm private memory archive."
) %>

<div class="flex min-h-screen flex-col bg-base-100">
  <header class="border-b border-base-200 bg-base-100">
    <div class="mx-auto flex w-full max-w-5xl items-center justify-between px-4 py-4">
      <%= link_to root_path, class: "text-lg font-semibold text-primary" do %>
        Parenting Connection
      <% end %>

      <nav class="flex items-center gap-2">
        <%= link_to "Log in",
              new_user_session_path,
              data: { turbo: false },
              class: "btn btn-ghost btn-sm" %>
        <%= link_to "Sign up",
              new_user_registration_path,
              data: { turbo: false },
              class: "btn btn-primary btn-sm" %>
      </nav>
    </div>
  </header>

  <main class="flex-1">
    <section class="mx-auto grid w-full max-w-5xl gap-10 px-4 py-14 md:grid-cols-[1.05fr_0.95fr] md:items-center md:py-20">
      <div class="space-y-7">
        <div class="space-y-4">
          <p class="text-sm font-medium text-primary">Private by default</p>
          <h1 class="text-4xl font-bold tracking-normal text-base-content sm:text-5xl">
            Preserve the conversations that reveal who your child is becoming.
          </h1>
          <p class="max-w-2xl text-lg leading-8 text-base-content/70">
            A calm daily ritual for asking one thoughtful question, saving the words
            and voice moments you want to remember, and returning to them over time.
          </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row">
          <%= link_to "Start a private archive",
                new_user_registration_path,
                data: { turbo: false },
                class: "btn btn-primary w-full sm:w-auto" %>
          <%= link_to "Log in",
                new_user_session_path,
                data: { turbo: false },
                class: "btn btn-outline w-full sm:w-auto" %>
        </div>
      </div>

      <section class="rounded-lg border border-base-200 bg-base-100 p-6 shadow-sm">
        <div class="space-y-6">
          <div>
            <p class="text-sm font-medium text-primary">One small loop</p>
            <h2 class="mt-2 text-2xl font-semibold text-base-content">
              Conversation becomes memory.
            </h2>
          </div>

          <ol class="space-y-4 text-base-content/75">
            <li class="flex gap-3">
              <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-semibold text-primary">1</span>
              <span>Choose a child and answer one gentle question together.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-semibold text-primary">2</span>
              <span>Save a written note, a voice memory, or both.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-semibold text-primary">3</span>
              <span>Return to a private archive that grows one conversation at a time.</span>
            </li>
          </ol>
        </div>
      </section>
    </section>
  </main>
</div>
